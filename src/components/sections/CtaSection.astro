---
import Button from '../ui/Button.astro';
import { siteConfig } from '../../config/site';
---

<section id="project-cta" class="section-padding section-adaptive relative overflow-hidden">
  <!-- Orbs -->
  <div class="orb orb-1" style="width:500px;height:500px;top:-100px;left:-100px;background:radial-gradient(ellipse,rgba(129,140,248,0.18) 0%,transparent 70%);" aria-hidden="true"></div>
  <div class="orb orb-2" style="width:400px;height:400px;bottom:-80px;right:-80px;background:radial-gradient(ellipse,rgba(192,132,252,0.15) 0%,transparent 70%);" aria-hidden="true"></div>
  <!-- Grid pattern -->
  <div class="absolute inset-0 bg-grid-pattern pointer-events-none" aria-hidden="true"></div>

  <div class="container-site text-center relative z-10">
    <div class="max-w-3xl mx-auto">
      <span class="label-tag text-[var(--color-fg-subtle)] reveal">Начнём?</span>
      <div class="divider my-4 mx-auto reveal reveal-delay-1" style="background-color: var(--color-accent);"></div>

      <h2
        class="text-[var(--color-fg)] font-light leading-tight mt-8 mb-6 reveal reveal-delay-2"
        style="font-size: clamp(1.75rem, 4.5vw, 3.5rem); letter-spacing: -0.02em;"
      >
        Готовы обсудить<br /><span class="gradient-text">ваш проект?</span>
      </h2>

      <p class="text-[var(--color-fg-muted)] text-base leading-relaxed mb-10 reveal reveal-delay-3">
        Расскажите, какой сайт или визуальное решение вам нужно — мы предложим формат, сроки и следующий шаг.
      </p>

      <Button href={siteConfig.cta.href} variant="primary" size="lg" class="reveal reveal-delay-4" pulse>
        {siteConfig.cta.label}
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <line x1="0" y1="7" x2="12" y2="7"/>
          <polyline points="8,3 12,7 8,11"/>
        </svg>
      </Button>
    </div>
  </div>
</section>
