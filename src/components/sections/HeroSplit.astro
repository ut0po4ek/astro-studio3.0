---
import ProjectSliderIsland from './ProjectSlider';
import HeroText from './HeroText';
import HeroCanvas from './HeroCanvas';
import { siteConfig } from '../../config/site';
import { getFeaturedProjects } from '../../data/portfolio';

const statsItems = [
  { value: '47', label: 'проектов' },
  { value: '100%', label: 'адаптивность' },
  { value: '→', label: 'запуск под ключ' },
];

const sliderProjects = getFeaturedProjects().map(p => ({
  slug: p.slug,
  title: p.title,
  tags: p.tags,
  image: { src: p.image.src },
  liveUrl: p.liveUrl,
}));
---

<section
  id="hero"
  class="relative min-h-dvh flex items-center hero-bg"
  aria-label="Главный экран"
>
  <!-- WebGL simplex noise shader — fluid dark background, highlights on mouse move -->
  <HeroCanvas client:load />

  <!-- Bottom gradient fade — transitions shader into page body -->
  <div class="hero-fade-bottom" aria-hidden="true"></div>

  <!-- Subtle vertical rule — gives grid structure without decoration -->
  <div class="hero-vline" aria-hidden="true"></div>

  <div class="container-site w-full py-28 md:py-36 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <!-- Left: text -->
      <div class="flex flex-col">
        <HeroText
          client:load
          ctaHref={siteConfig.cta.href}
          portfolioHref="/portfolio"
          ctaLabel={siteConfig.cta.label}
          statsItems={statsItems}
        />
      </div>

      <!-- Right: project slider -->
      <div class="relative" data-reveal data-reveal-delay="200">
        <ProjectSliderIsland client:load projects={sliderProjects} />
      </div>

    </div>
  </div>
</section>

<style>
  /* Bottom gradient: shader → page background */
  .hero-fade-bottom {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    height: 200px;
    background: linear-gradient(to bottom, transparent, var(--color-bg));
    pointer-events: none;
    z-index: 1;
  }

  /* ── Vertical axis — structural grid line with scan particle ── */
  .hero-vline {
    position: absolute;
    top: 10%;
    bottom: 10%;
    left: 50%;
    width: 1px;
    z-index: 2;
    pointer-events: none;
    transform-origin: top center;
    overflow: visible;

    /* Gradient line: transparent → indigo peak at center → transparent */
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(129, 140, 248, 0.28) 18%,
      rgba(192, 132, 252, 0.55) 50%,
      rgba(129, 140, 248, 0.28) 82%,
      transparent 100%
    );

    /* Ambient line glow */
    box-shadow:
      0 0 4px rgba(129, 140, 248, 0.12),
      0 0 12px rgba(192, 132, 252, 0.06);

    animation: vline-in 1.1s cubic-bezier(0.16, 1, 0.3, 1) 0.5s both;
  }

  /* ── Scan particle — travels top→bottom on loop ── */
  .hero-vline::before {
    content: '';
    position: absolute;
    left: -3px;
    top: 0%;
    width: 7px;
    height: 28px;
    border-radius: 4px;

    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(192, 132, 252, 0.85) 40%,
      rgba(129, 140, 248, 0.95) 60%,
      transparent 100%
    );
    filter: blur(0.5px);
    box-shadow:
      0 0 6px 1px rgba(129, 140, 248, 0.45),
      0 0 14px 2px rgba(192, 132, 252, 0.22);

    /* Particle starts after line draws in (1.6s) */
    animation: scan-particle 5s cubic-bezier(0.45, 0, 0.55, 1) 1.8s infinite;
    opacity: 0;
  }

  /* ── Crosshair node — small ring at the vertical midpoint ── */
  .hero-vline::after {
    content: '';
    position: absolute;
    top: 50%;
    left: -4px;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    transform: translateY(-50%);
    border: 1px solid rgba(192, 132, 252, 0.50);
    background: rgba(129, 140, 248, 0.10);
    box-shadow:
      0 0 6px rgba(192, 132, 252, 0.30),
      inset 0 0 4px rgba(129, 140, 248, 0.15);

    /* Slow breathe pulse */
    animation: node-pulse 3s ease-in-out 2.2s infinite;
  }

  @keyframes vline-in {
    from { transform: scaleY(0); opacity: 0; }
    to   { transform: scaleY(1); opacity: 1; }
  }

  @keyframes scan-particle {
    0%   { top: 0%;               opacity: 0;   }
    4%   { opacity: 1;             }
    48%  { top: calc(100% - 28px); opacity: 0.8; }
    51%  { top: calc(100% - 28px); opacity: 0;   }
    52%  { top: 0%;               opacity: 0;   }
    56%  { opacity: 1;             }
    96%  { top: calc(100% - 28px); opacity: 0.8; }
    100% { top: calc(100% - 28px); opacity: 0;   }
  }

  @keyframes node-pulse {
    0%, 100% {
      box-shadow: 0 0 6px rgba(192, 132, 252, 0.30), inset 0 0 4px rgba(129, 140, 248, 0.15);
      border-color: rgba(192, 132, 252, 0.50);
    }
    50% {
      box-shadow: 0 0 12px rgba(192, 132, 252, 0.55), 0 0 24px rgba(129, 140, 248, 0.18), inset 0 0 6px rgba(129, 140, 248, 0.25);
      border-color: rgba(192, 132, 252, 0.80);
    }
  }

  @media (max-width: 1023px) {
    .hero-vline { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-vline {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .hero-vline::before { animation: none; display: none; }
    .hero-vline::after  { animation: none; }
  }

  /* Hero background matches the shader's initial clearColor so there's no
     flash/blank frame during Astro view-transition unmount/remount of the
     React <HeroCanvas> component. Override per theme. */
  .hero-bg {
    background: #020206; /* DARK_PALETTE.canvasBg */
  }
  [data-theme="light"] .hero-bg {
    background: #f6f4ff; /* LIGHT_PALETTE.canvasBg */
  }

</style>
