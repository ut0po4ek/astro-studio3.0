---
import ProjectSliderIsland from './ProjectSlider';
import HeroText from './HeroText';
import { siteConfig } from '../../config/site';
import { getFeaturedProjects } from '../../data/portfolio';

const statsItems = [
  { value: '4', label: 'проекта' },
  { value: '100%', label: 'адаптивность' },
  { value: '→', label: 'запуск под ключ' },
];

const sliderProjects = getFeaturedProjects().map(p => ({
  slug: p.slug,
  title: p.title,
  tags: p.tags,
  image: { src: p.image.src },
  liveUrl: p.liveUrl,
}));
---

<section
  id="hero"
  class="relative min-h-screen flex items-center overflow-hidden"
  style="background: var(--color-bg);"
  aria-label="Главный экран"
>
  <!-- Animated gradient orbs -->
  <div class="orb orb-1" style="width:600px;height:600px;top:-100px;left:-150px;background:radial-gradient(ellipse,rgba(129,140,248,0.22) 0%,transparent 70%);" aria-hidden="true"></div>
  <div class="orb orb-2" style="width:500px;height:500px;top:30%;right:-100px;background:radial-gradient(ellipse,rgba(192,132,252,0.18) 0%,transparent 70%);" aria-hidden="true"></div>
  <div class="orb orb-3" style="width:400px;height:400px;bottom:0;left:40%;background:radial-gradient(ellipse,rgba(99,102,241,0.15) 0%,transparent 70%);" aria-hidden="true"></div>

  <!-- Grid pattern overlay -->
  <div class="absolute inset-0 bg-grid-pattern pointer-events-none" aria-hidden="true"></div>

  <!-- Decorative curved SVG line (scroll-drawn) -->
  <div class="hero-curve-wrap absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <svg
      class="hero-curve-svg absolute"
      style="left: 50%; top: 18%; transform: translateX(-50%); width: 80vw; max-width: 900px; opacity: 0.45;"
      viewBox="0 0 900 220"
      fill="none"
      preserveAspectRatio="none"
    >
      <path
        id="hero-curve-path"
        d="M 0,110 C 120,20 240,200 360,110 C 480,20 600,200 720,110 C 800,50 860,130 900,110"
        stroke="var(--color-accent)"
        stroke-width="1"
        fill="none"
        stroke-linecap="round"
      />
    </svg>
  </div>

  <div class="hero-vertical-line" aria-hidden="true"></div>

  <div class="container-site w-full py-24 md:py-32 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left: text island -->
      <div class="flex flex-col gap-6 lg:gap-8">
        <HeroText
          client:load
          ctaHref={siteConfig.cta.href}
          portfolioHref="/portfolio"
          ctaLabel={siteConfig.cta.label}
          statsItems={statsItems}
        />
      </div>

      <!-- Right: slider -->
      <div class="relative" data-reveal data-reveal-delay="200">
        <ProjectSliderIsland client:load projects={sliderProjects} />
      </div>
    </div>
  </div>
</section>

<style>
  /* Animated orbs */
  .orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
    will-change: transform;
  }

  .orb-1 {
    animation: orb-float-1 18s ease-in-out infinite;
  }
  .orb-2 {
    animation: orb-float-2 22s ease-in-out infinite;
  }
  .orb-3 {
    animation: orb-float-3 16s ease-in-out infinite;
  }

  @keyframes orb-float-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33%       { transform: translate(30px, 20px) scale(1.04); }
    66%       { transform: translate(-20px, 40px) scale(0.97); }
  }
  @keyframes orb-float-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    40%       { transform: translate(-40px, -25px) scale(1.05); }
    70%       { transform: translate(20px, 30px) scale(0.96); }
  }
  @keyframes orb-float-3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%       { transform: translate(25px, -35px) scale(1.06); }
  }

  /* Grid pattern */
  .bg-grid-pattern {
    background-image:
      linear-gradient(var(--color-border, rgba(255,255,255,0.05)) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-border, rgba(255,255,255,0.05)) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.4;
    z-index: 0;
  }

  /* Offset border — fades in and slides from slight offset */
  @keyframes hero-border-in {
    from {
      opacity: 0;
      transform: translate(8px, -8px);
    }
    to {
      opacity: 1;
      transform: translate(0, 0);
    }
  }
  .hero-offset-border {
    animation: hero-border-in 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.8s both;
  }

  @keyframes hero-line-y {
    from {
      opacity: 0;
      transform: scaleY(0);
    }
    to {
      opacity: 1;
      transform: scaleY(1);
    }
  }

  .hero-vertical-line {
    position: absolute;
    top: 12%;
    bottom: 12%;
    left: 50%;
    width: 1px;
    z-index: 1;
    pointer-events: none;
    transform-origin: top;
    background: linear-gradient(
      to bottom,
      transparent,
      var(--color-border) 16%,
      var(--color-border) 84%,
      transparent
    );
    animation: hero-line-y 1.1s cubic-bezier(0.16, 1, 0.3, 1) 0.45s both;
  }

  @media (max-width: 1023px) {
    .hero-vertical-line {
      display: none;
    }
  }

  /* Curved SVG path draw-in animation */
  @keyframes curve-draw {
    from { stroke-dashoffset: var(--path-length, 2000); }
    to   { stroke-dashoffset: 0; }
  }
  #hero-curve-path {
    stroke-dasharray: 2000;
    stroke-dashoffset: 2000;
    animation: curve-draw 2.4s cubic-bezier(0.16, 1, 0.3, 1) 0.6s both;
  }

  @media (prefers-reduced-motion: reduce) {
    .orb-1, .orb-2, .orb-3 {
      animation: none !important;
    }
    .hero-offset-border,
    .hero-vertical-line,
    #hero-curve-path {
      animation: none !important;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  function initHeroCurve() {
    const path = document.getElementById('hero-curve-path') as SVGPathElement | null;
    if (!path) return;
    const length = path.getTotalLength();
    path.style.strokeDasharray = String(length);
    path.style.strokeDashoffset = String(length);
    path.style.animation = `curve-draw 2.4s cubic-bezier(0.16, 1, 0.3, 1) 0.6s both`;
  }

  document.addEventListener('astro:page-load', initHeroCurve);
  initHeroCurve();
</script>
