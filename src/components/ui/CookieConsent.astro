---
// Cookie consent banner — shown once per year per visitor.
// Stores choice in localStorage under key 'cookie_consent'.
// Values: 'all' | 'necessary'
---

<div id="cookie-banner" class="cookie-banner" role="dialog" aria-modal="true" aria-label="Уведомление о cookies" hidden>
  <div class="cookie-banner__inner">
    <p class="cookie-banner__text">
      Мы используем cookies для корректной работы сайта и аналитики.
      Подробнее — в <a href="/cookies" class="cookie-banner__link">Политике cookies</a>.
    </p>
    <div class="cookie-banner__actions">
      <button id="cookie-accept-all" class="cookie-btn cookie-btn--primary">
        Принять все
      </button>
      <button id="cookie-accept-necessary" class="cookie-btn cookie-btn--ghost">
        Только необходимые
      </button>
    </div>
  </div>
</div>

<script>
  const CONSENT_KEY = 'cookie_consent';
  const CONSENT_TTL = 365 * 24 * 60 * 60 * 1000; // 1 year

  function getConsent(): { value: string; ts: number } | null {
    try {
      const raw = localStorage.getItem(CONSENT_KEY);
      return raw ? JSON.parse(raw) : null;
    } catch {
      return null;
    }
  }

  function saveConsent(value: 'all' | 'necessary') {
    try {
      localStorage.setItem(CONSENT_KEY, JSON.stringify({ value, ts: Date.now() }));
    } catch {/* storage unavailable */}
  }

  function isConsentValid(): boolean {
    const consent = getConsent();
    if (!consent) return false;
    return Date.now() - consent.ts < CONSENT_TTL;
  }

  function hideBanner() {
    const banner = document.getElementById('cookie-banner');
    if (!banner) return;
    banner.classList.remove('cookie-banner--visible');
    setTimeout(() => banner.setAttribute('hidden', ''), 350);
  }

  function initBanner() {
    if (isConsentValid()) return;

    const banner = document.getElementById('cookie-banner');
    if (!banner) return;

    banner.removeAttribute('hidden');
    // Allow hidden → visible transition
    requestAnimationFrame(() => {
      requestAnimationFrame(() => banner.classList.add('cookie-banner--visible'));
    });

    document.getElementById('cookie-accept-all')?.addEventListener('click', () => {
      saveConsent('all');
      hideBanner();
    });

    document.getElementById('cookie-accept-necessary')?.addEventListener('click', () => {
      saveConsent('necessary');
      hideBanner();
    });
  }

  // Run on initial load and after Astro view transitions
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBanner, { once: true });
  } else {
    initBanner();
  }
  document.addEventListener('astro:page-load', initBanner);
</script>

<style>
.cookie-banner {
  position: fixed;
  bottom: 1.5rem;
  left: 50%;
  transform: translateX(-50%) translateY(calc(100% + 2rem));
  z-index: 9000;
  width: calc(100vw - 2rem);
  max-width: 44rem;
  opacity: 0;
  transition:
    transform 350ms cubic-bezier(0.16, 1, 0.3, 1),
    opacity   350ms ease;
  pointer-events: none;
}

.cookie-banner--visible {
  transform: translateX(-50%) translateY(0);
  opacity: 1;
  pointer-events: auto;
}

.cookie-banner__inner {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding: 1rem 1.25rem;
  border-radius: 1rem;
  border: 1px solid var(--color-border-bright);
  background: var(--color-bg-elevated);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  box-shadow:
    0 8px 32px rgba(0, 0, 0, 0.36),
    inset 0 1px 0 rgba(255, 255, 255, 0.06);
}

.cookie-banner__text {
  font-size: 0.875rem;
  line-height: 1.55;
  color: var(--color-fg-muted);
  flex: 1 1 16rem;
  margin: 0;
}

.cookie-banner__link {
  color: var(--color-accent);
  text-decoration: underline;
  text-underline-offset: 2px;
}

.cookie-banner__actions {
  display: flex;
  flex-shrink: 0;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.cookie-btn {
  display: inline-flex;
  align-items: center;
  padding: 0.5rem 1.125rem;
  border-radius: 9999px;
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.04em;
  cursor: pointer;
  transition: opacity 180ms ease, background 180ms ease;
  white-space: nowrap;
  border: none;
}

.cookie-btn--primary {
  background: var(--gradient-accent);
  color: #fff;
}
.cookie-btn--primary:hover { opacity: 0.88; }

.cookie-btn--ghost {
  background: transparent;
  color: var(--color-fg-muted);
  border: 1px solid var(--color-border);
}
.cookie-btn--ghost:hover {
  color: var(--color-fg);
  border-color: var(--color-border-bright);
}
</style>
