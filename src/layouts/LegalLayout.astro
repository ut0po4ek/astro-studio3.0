---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { siteConfig } from '../config/site';

interface Props {
  title: string;
  description?: string;
  updatedAt?: string;
}

const { title, description, updatedAt } = Astro.props;

const formattedDate = updatedAt
  ? new Date(updatedAt).toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' })
  : null;
---

<BaseLayout
  title={`${title} — ${siteConfig.name}`}
  description={description ?? `${title}. Юридические документы ${siteConfig.name}.`}
>
  <Header />
  <main class="legal-main">
    <div class="legal-container">

      <nav class="legal-breadcrumb" aria-label="Путь">
        <a href="/">Главная</a>
        <span aria-hidden="true">›</span>
        <span>{title}</span>
      </nav>

      <article class="legal-article">
        <header class="legal-header">
          <h1 class="legal-title">{title}</h1>
          {formattedDate && (
            <p class="legal-meta">Последнее обновление: {formattedDate}</p>
          )}
        </header>

        <div class="legal-body">
          <slot />
        </div>
      </article>

      <nav class="legal-other-docs" aria-label="Другие документы">
        <p class="legal-other-label">Другие документы</p>
        <ul class="legal-other-list">
          {siteConfig.footer.legal.map((doc) => (
            <li>
              <a
                href={doc.href}
                class:list={['legal-other-link', { 'legal-other-link--current': Astro.url.pathname === doc.href }]}
              >
                {doc.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
.legal-main {
  background: var(--color-bg);
  padding-block: clamp(5rem, 10vw, 8rem) clamp(4rem, 8vw, 6rem);
  min-height: 70vh;
}

.legal-container {
  max-width: 52rem;
  margin-inline: auto;
  padding-inline: clamp(1.25rem, 5vw, 2.5rem);
}

.legal-breadcrumb {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.75rem;
  color: var(--color-fg-muted);
  margin-bottom: 2.5rem;
}
.legal-breadcrumb a {
  color: var(--color-fg-muted);
  text-decoration: none;
  transition: color 150ms ease;
}
.legal-breadcrumb a:hover { color: var(--color-fg); }
.legal-breadcrumb span[aria-hidden] { opacity: 0.4; }

.legal-header {
  margin-bottom: 2.5rem;
  padding-bottom: 2rem;
  border-bottom: 1px solid var(--color-border);
}

.legal-title {
  font-size: clamp(1.75rem, 4vw, 2.5rem);
  font-weight: 600;
  letter-spacing: -0.025em;
  line-height: 1.15;
  color: var(--color-fg);
  margin-bottom: 0.75rem;
}

.legal-meta {
  font-size: 0.8125rem;
  color: var(--color-fg-muted);
  opacity: 0.7;
}

.legal-body {
  color: var(--color-fg);
  font-size: 0.9375rem;
  line-height: 1.75;
}

.legal-body :global(h2) {
  font-size: 1.0625rem;
  font-weight: 600;
  letter-spacing: -0.01em;
  margin-top: 2.5rem;
  margin-bottom: 0.75rem;
  color: var(--color-fg);
}

.legal-body :global(h3) {
  font-size: 0.9375rem;
  font-weight: 600;
  margin-top: 1.75rem;
  margin-bottom: 0.5rem;
  color: var(--color-fg);
}

.legal-body :global(p) {
  margin-bottom: 1rem;
  color: var(--color-fg-muted);
}

.legal-body :global(ul),
.legal-body :global(ol) {
  padding-left: 1.5rem;
  margin-bottom: 1rem;
  color: var(--color-fg-muted);
}

.legal-body :global(li) {
  margin-bottom: 0.375rem;
}

.legal-body :global(a) {
  color: var(--color-accent);
  text-decoration: underline;
  text-underline-offset: 3px;
}

.legal-body :global(strong) {
  font-weight: 600;
  color: var(--color-fg);
}

.legal-body :global(.notice) {
  background: var(--color-bg-elevated);
  border: 1px solid var(--color-border);
  border-radius: 0.625rem;
  padding: 1rem 1.25rem;
  margin-block: 1.5rem;
  font-size: 0.875rem;
  color: var(--color-fg-muted);
}

.legal-other-docs {
  margin-top: 4rem;
  padding-top: 2rem;
  border-top: 1px solid var(--color-border);
}

.legal-other-label {
  font-size: 0.6875rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-fg-muted);
  opacity: 0.6;
  margin-bottom: 1rem;
}

.legal-other-list {
  list-style: none;
  padding: 0;
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.legal-other-link {
  display: inline-block;
  padding: 0.375rem 0.875rem;
  border-radius: 9999px;
  border: 1px solid var(--color-border);
  font-size: 0.75rem;
  color: var(--color-fg-muted);
  text-decoration: none;
  transition: color 150ms ease, border-color 150ms ease, background 150ms ease;
}
.legal-other-link:hover {
  color: var(--color-fg);
  border-color: var(--color-border-bright);
}
.legal-other-link--current {
  color: var(--color-accent);
  border-color: var(--color-accent);
  pointer-events: none;
}
</style>
