---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import ContactSection from '../components/sections/ContactSection.astro';
import Icon from '../components/ui/Icon.astro';
import PageHeroCanvas from '../components/ui/PageHeroCanvas.astro';
import { siteConfig } from '../config/site';
import { getFeaturedProjects } from '../data/portfolio';

const previewProjects = getFeaturedProjects().map(p => ({
  src: p.image.src,
  href: `/portfolio/${p.slug}`,
}));

const channels = [
  {
    icon: 'telegram',
    title: 'Telegram',
    desc: 'Самый быстрый способ. Отвечаем в течение часа в рабочее время.',
    href: siteConfig.contacts.telegram,
    label: 'Написать в Telegram',
  },
  {
    icon: 'email',
    title: 'Email',
    desc: 'Для развёрнутых брифов, документов и официальной переписки.',
    href: `mailto:${siteConfig.contacts.email}`,
    label: 'Написать на почту',
  },
];

const showcaseChannels = siteConfig.showcaseChannels;

const workingHours = [
  { day: 'Пн — Пт', time: '10:00 — 20:00' },
  { day: 'Суббота', time: '11:00 — 18:00' },
  { day: 'Воскресенье', time: 'выходной' },
];

const faqs = [
  {
    q: 'Как быстро вы отвечаете?',
    a: 'В рабочее время — в течение 1–2 часов. Вечером и в выходные — в течение нескольких часов. Срочные вопросы лучше решать через Telegram.',
  },
  {
    q: 'Что нужно подготовить для первого разговора?',
    a: 'Ничего особенного. Достаточно рассказать: что за проект, какая цель сайта и примерные сроки. Остальное выясним на брифинге.',
  },
  {
    q: 'Работаете ли вы удалённо?',
    a: 'Да, работаем полностью удалённо по всей России и СНГ. Общение через мессенджеры и видеозвонки — без потери в качестве.',
  },
];
---

<BaseLayout
  title="Контакты — Astro Studio"
  description="Свяжитесь с Astro Studio, чтобы обсудить сайт, лендинг или digital-дизайн."
>
  <Header />
  <main>

    <!-- Inner-page hero — atmospheric shader backdrop -->
    <section
      id="hero"
      class="page-hero relative overflow-hidden flex flex-col justify-center"
      aria-label="Контакты — заголовок"
      transition:name="page-hero-contacts"
      transition:animate="none"
    >
      <PageHeroCanvas />
      <div class="absolute inset-0 z-1 pointer-events-none"
        style="background: linear-gradient(to bottom, rgba(2,2,7,0.30) 0%, transparent 40%, transparent 60%, rgba(2,2,7,0.55) 100%);"
        aria-hidden="true"></div>
      <div class="page-hero-fade" aria-hidden="true"></div>

      <div class="container-site relative z-10">
        <span
          class="text-[10px] font-medium tracking-[0.25em] uppercase mb-4 block"
          style="color: rgba(167,139,250,0.80);"
          data-reveal
        >
          Contact
        </span>
        <h1
          class="font-light mb-5 text-white"
          style="font-size: clamp(2.5rem, 6.5vw, 4.5rem); letter-spacing: -0.03em; line-height: 1.05;"
          data-reveal data-reveal-delay="100"
        >
          Начнём работу?
        </h1>
        <p
          class="leading-relaxed max-w-lg"
          style="font-size: 1.0625rem; color: rgba(247,241,231,0.62);"
          data-reveal data-reveal-delay="200"
        >
          Расскажите о проекте — ответим, предложим формат и следующий шаг.
        </p>
      </div>
    </section>

    <!-- Channels -->
    <section class="border-t border-[var(--color-border)]" style="background: var(--color-bg-warm);">
      <div class="container-site py-12 md:py-16">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {channels.map((ch, i) => (
            <a
              href={ch.href}
              target={ch.href.startsWith('mailto:') ? undefined : '_blank'}
              rel="noreferrer"
              class="contact-channel-card group flex flex-col gap-4 p-6 rounded-xl border border-[var(--color-border)] hover:border-[var(--color-accent)] transition-colors duration-500"
              style="transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);"
              data-reveal
              data-reveal-delay={i * 80}
            >
              <div class="flex items-center gap-3">
                <span class="w-10 h-10 flex items-center justify-center border border-[var(--color-border)] rounded-full group-hover:border-[var(--color-accent)] group-hover:text-[var(--color-accent)] transition-all duration-300 text-[var(--color-fg-muted)]">
                  <Icon name={ch.icon as any} size={18} />
                </span>
                <span class="text-[var(--color-fg)] font-medium text-sm">{ch.title}</span>
              </div>
              <p class="text-[var(--color-fg-muted)] text-sm leading-relaxed">{ch.desc}</p>
              <span class="text-[var(--color-accent)] text-xs font-medium tracking-wide uppercase flex items-center gap-1 mt-auto group-hover:gap-2 group-hover:underline transition-all duration-300" style="text-underline-offset: 3px;">
                {ch.label} →
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Telegram showcase channels — not in footer/contact section by design -->
    <section class="border-t border-[var(--color-border)]" style="background: var(--color-bg);">
      <div class="container-site py-12 md:py-16">
        <p class="label-tag mb-6" data-reveal>Наши Telegram-каналы</p>
        <p class="text-[var(--color-fg-muted)] text-sm leading-relaxed mb-8 max-w-2xl" data-reveal data-reveal-delay="60">
          Помимо личной переписки, мы ведём два канала, где выкладываем наши работы, процесс разработки и кейсы.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {showcaseChannels.map((ch, i) => (
            <a
              href={ch.href}
              target="_blank"
              rel="noreferrer"
              class="contact-channel-card group flex flex-col gap-4 p-6 rounded-xl border border-[var(--color-border)] hover:border-[var(--color-accent)] transition-colors duration-500"
              style="transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);"
              data-reveal
              data-reveal-delay={i * 80}
            >
              <div class="flex items-center gap-3">
                <span class="w-10 h-10 flex items-center justify-center border border-[var(--color-border)] rounded-full group-hover:border-[var(--color-accent)] group-hover:text-[var(--color-accent)] transition-all duration-300 text-[var(--color-fg-muted)]">
                  <Icon name="telegram" size={18} />
                </span>
                <span class="text-[var(--color-fg)] font-medium text-sm">{ch.label}</span>
              </div>
              <p class="text-[var(--color-fg-muted)] text-sm leading-relaxed">Выкладываем наши работы и кейсы студии.</p>
              <span class="text-[var(--color-accent)] text-xs font-medium tracking-wide uppercase flex items-center gap-1 mt-auto group-hover:gap-2 group-hover:underline transition-all duration-300" style="text-underline-offset: 3px;">
                Открыть канал →
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Contact form + working hours -->
    <ContactSection />

    <!-- Working hours + FAQ -->
    <section class="section-padding border-t border-[var(--color-border)]" style="background: var(--color-bg-warm);">
      <div class="container-site">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

          <!-- Working hours -->
          <div>
            <p class="label-tag mb-6" data-reveal>График работы</p>
            <div class="flex flex-col divide-y divide-[var(--color-border)]">
              {workingHours.map((wh, i) => (
                <div
                  class="flex items-center justify-between py-4"
                  data-reveal
                  data-reveal-delay={i * 60}
                >
                  <span class="text-[var(--color-fg)] text-sm">{wh.day}</span>
                  <span class="text-[var(--color-fg-muted)] text-sm">{wh.time}</span>
                </div>
              ))}
            </div>
            <div class="mt-8 p-5 rounded-xl border border-[var(--color-border)]" data-reveal data-reveal-delay="200">
              <p class="text-[var(--color-fg)] text-sm font-medium mb-2">Среднее время ответа</p>
              <p class="text-[var(--color-fg-muted)] text-sm leading-relaxed">
                В рабочее время — до 1–2 часов. В Telegram отвечаем быстрее всего.
              </p>
            </div>
          </div>

          <!-- Mini FAQ -->
          <div>
            <p class="label-tag mb-6" data-reveal>Вопросы перед первым сообщением</p>
            <div class="flex flex-col divide-y divide-[var(--color-border)]">
              {faqs.map((faq, i) => (
                <div
                  class="py-5"
                  data-reveal
                  data-reveal-delay={i * 80}
                >
                  <h3 class="text-[var(--color-fg)] font-medium text-sm mb-2">{faq.q}</h3>
                  <p class="text-[var(--color-fg-muted)] text-sm leading-relaxed">{faq.a}</p>
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Portfolio mini strip -->
    <section class="section-padding border-t border-[var(--color-border)]" style="background: var(--color-bg);">
      <div class="container-site">
        <p class="label-tag mb-6 text-center" data-reveal>Посмотрите, что мы делаем</p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3" data-reveal data-reveal-delay="100">
          {previewProjects.map(item => (
            <a href={item.href} class="group aspect-video overflow-hidden rounded-lg border border-[var(--color-border)] hover:border-[var(--color-accent)] transition-all duration-500">
              <img
                src={item.src}
                alt="Проект"
                class="w-full h-full object-cover object-top transition-transform duration-500 ease-out group-hover:scale-105"
                loading="lazy"
              />
            </a>
          ))}
        </div>
        <div class="text-center mt-8" data-reveal data-reveal-delay="200">
          <a href="/portfolio" class="portfolio-view-link">
            <span class="portfolio-view-link__text">Смотреть все проекты</span>
            <svg class="portfolio-view-link__arrow" width="13" height="13" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <line x1="0" y1="14" x2="14" y2="0"/>
              <polyline points="5,0 14,0 14,9"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
