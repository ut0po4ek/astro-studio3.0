---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import TagFilter from '../../components/portfolio/TagFilter';
import PageHeroCanvas from '../../components/ui/PageHeroCanvas.astro';
import { portfolio } from '../../data/portfolio';

const allTags = [...new Set(portfolio.flatMap(p => p.tags))].sort();
const projects = portfolio.map(p => ({
  slug: p.slug,
  title: p.title,
  shortDescription: p.shortDescription,
  tags: p.tags,
  category: p.category ?? '',
  image: { src: p.image.src },
}));
---

<BaseLayout title="Портфолио — Astro Studio" description="Все проекты студии: сайты, лендинги и visual-решения.">
  <Header />
  <main>
    <!-- Inner-page hero — atmospheric shader backdrop -->
    <section
      id="hero"
      class="page-hero relative overflow-hidden flex flex-col justify-center"
      aria-label="Портфолио — заголовок"
      transition:name="page-hero-portfolio"
      transition:animate="none"
    >
      <PageHeroCanvas />
      <div class="absolute inset-0 z-1 pointer-events-none"
        style="background: linear-gradient(to bottom, rgba(2,2,7,0.30) 0%, transparent 40%, transparent 60%, rgba(2,2,7,0.55) 100%);"
        aria-hidden="true"></div>
      <div class="page-hero-fade" aria-hidden="true"></div>

      <div class="container-site relative z-10">
        <span
          class="text-[10px] font-medium tracking-[0.25em] uppercase mb-4 block"
          style="color: rgba(167,139,250,0.80);"
          data-reveal
        >
          Portfolio
        </span>
        <h1
          class="font-light mb-5 text-white"
          style="font-size: clamp(2.5rem, 6.5vw, 4.5rem); letter-spacing: -0.03em; line-height: 1.05;"
          data-reveal data-reveal-delay="100"
        >
          Работы <em style="font-style:normal; color: rgba(167,139,250,0.95);">студии</em>
        </h1>
        <p
          class="leading-relaxed"
          style="font-size: 1.0625rem; color: rgba(247,241,231,0.62); max-width: 440px;"
          data-reveal data-reveal-delay="200"
        >
          Сайты, лендинги и visual-решения, которые мы создаём для брендов.
        </p>
      </div>
    </section>

    <!-- Portfolio grid -->
    <section style="background: var(--color-bg); padding-top: clamp(3rem, 6vw, 5rem); padding-bottom: clamp(3rem, 8vw, 6rem);">
      <div class="container-site relative z-10">
        <TagFilter client:load projects={projects} allTags={allTags} />
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
